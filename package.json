{
  "name": "pc-console",
  "version": "1.0.0",
  "description": "Console-like PC gaming launcher",
  "main": "electron/main.js",
  "scripts": {
    "dev": "concurrently -n vite,electron \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "build": "vite build && electron-builder",
    "start": "electron .",
    "vite": "vite"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.0",
    "concurrently": "^9.0.0",
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0",
    "vite": "^6.0.0",
    "wait-on": "^8.0.0"
  },
  "dependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "build": {
    "appId": "com.pcconsole.app",
    "productName": "PC Console",
    "win": {
      "target": "nsis",
      "icon": "public/icon.png"
    },
    "files": [
      "dist/**/*",
      "electron/**/*"
    ]
  }
}
